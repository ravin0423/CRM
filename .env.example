# ============================================================
# Internal Support CRM — Bootstrap Environment Variables
# ============================================================
# Copy this file to .env and fill in values for first-time boot.
# After the Admin Panel is configured, settings are read from
# config/admin_settings.json and these vars are ignored.

# --- Required ---
# 32-byte url-safe base64 key for encrypting secrets at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CRM_MASTER_KEY_B64=

# --- Database bootstrap (used until Admin Panel configures DB) ---
# Options: sqlserver, mongodb, sqlite (dev only)
CRM_BOOTSTRAP_DB=sqlserver
# CRM_BOOTSTRAP_POSTGRES_URL=postgresql://crm:crm_change_me@localhost:5432/crm_meta

# --- Runtime ---
# Environment: development | staging | production
CRM_ENV=production

# Log level: DEBUG | INFO | WARNING | ERROR
CRM_LOG_LEVEL=INFO

# CORS allowed origins (comma-separated). Use * for dev only.
CRM_CORS_ORIGINS=https://crm.yourcompany.com

# Path to the admin settings JSON file
CRM_CONFIG_PATH=./config/admin_settings.json

# --- Optional: direct database URL (bypasses ConfigManager for migrations) ---
# CRM_DATABASE_URL=mssql+pyodbc://user:pass@server/db?driver=ODBC+Driver+18+for+SQL+Server
