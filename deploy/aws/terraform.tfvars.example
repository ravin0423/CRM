# Copy to terraform.tfvars and fill in. Do NOT commit terraform.tfvars.

aws_region  = "us-east-1"
environment = "prod"

# Existing EC2 key-pair name — you create this in the console ahead of time.
key_name = "your-ec2-keypair"

# Docker images — published somewhere your EC2 hosts can pull from.
backend_image  = "ghcr.io/your-org/crm-backend:v1.0.0"
frontend_image = "ghcr.io/your-org/crm-frontend:v1.0.0"

# RDS credentials.
db_admin_username = "crmadmin"
db_admin_password = "CHANGE-ME-to-a-long-random-string"

# Amazon MQ credentials.
mq_admin_username = "crmadmin"
mq_admin_password = "CHANGE-ME-to-a-long-random-string"

# S3 bucket — must be globally unique across all of AWS.
attachments_bucket_name = "crm-attachments-your-suffix-here"

# Optional DNS. Leave blank to skip and use the ALB DNS directly.
dns_zone_id     = ""
dns_record_name = ""

# Lock down ingress in production.
admin_allowed_cidrs = ["0.0.0.0/0"]
ssh_allowed_cidrs   = []
